rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // For simplicity, we'll allow a specific UID or check an 'admins' collection
      // In a real app, you'd bootstrap this. Let's assume admins are in /admins/{uid}
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Admins - Allow first user or owner to become admin
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.token.email in ['nilanrumal@gmail.com', 'rumalfernando@gmail.com'] ||
        !exists(/databases/$(database)/documents/admins/bootstrap) || 
        isAdmin()
      );
      allow update, delete: if isAdmin();
    }
    
    // Bootstrap tracking
    match /admins/bootstrap {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    // Site Config
    match /siteConfig/{configId} {
      allow read: if true; // Public read
      allow write: if isAdmin();
    }

    // Chats
    match /chats/{chatId} {
      allow get: if (isSignedIn() && (resource.data.userId == request.auth.uid)) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && ((resource.data.userId == request.auth.uid) || isAdmin());
    }

    // Messages
    match /chats/{chatId}/messages/{messageId} {
      allow read: if (isSignedIn() && (get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid)) || isAdmin();
      allow create: if isSignedIn() && (
        (get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid && request.resource.data.type != 'agent')
        || isAdmin()
      );
    }
  }
}
